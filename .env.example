# Configuración de producción de Gestiona más.
# Copia este archivo a ".env" y rellénalo en el servidor (NO lo subas a git).

# Activa el modo producción (exige clave secreta y usuarios).
GESTIONA_ENV=production

# Clave secreta para firmar las sesiones. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
GESTIONA_SECRET_KEY=pon-aqui-una-clave-larga-y-secreta

# Duración de la sesión en horas (opcional, por defecto 8).
GESTIONA_SESSION_HORAS=8

# Registro autoservicio: ÚNICO código de invitación (siempre válido) que compartes
# con la gente autorizada. Es el mismo para todos. Cámbialo por uno tuyo en producción.
GESTIONA_CODIGO_REGISTRO=pon-aqui-tu-codigo-de-invitacion

# Usuarios admin (opcional): lo normal es que cada uno se registre, o crearlos con
# `python crear_usuario.py`. Alternativa para un único usuario por entorno:
# GESTIONA_USER=admin
# GESTIONA_PASSWORD_HASH=pbkdf2_sha256$200000$...   (genera con crear_usuario.py)

# --- Asistente del editor de informes (opcional) --------------------------
# Chatbot que interpreta peticiones en lenguaje natural en el editor de informes
# (endpoint /api/informe/chat), con la API de OpenAI. Sin esta clave el editor
# usa su parser local de respaldo; el resto de la app funciona igual.
# OPENAI_API_KEY=sk-...
# GESTIONA_CHAT_MODELO=gpt-4o-mini                   (gpt-4o-mini)

# --- Razonador de IA (opcional) -------------------------------------------
# Segunda opinión de Claude sobre el análisis, BAJO DEMANDA (endpoint
# /api/informe/{huella}/revisar-ia). Sin esta clave la app funciona igual que
# hoy: el motor determinista es siempre la fuente de verdad y la revisión con
# IA simplemente no se ofrece.
# ANTHROPIC_API_KEY=sk-ant-...
#
# Ajustes opcionales (valores por defecto entre paréntesis):
# GESTIONA_RAZONADOR_MODELO=claude-opus-4-8          (claude-opus-4-8)
# GESTIONA_RAZONADOR_EFFORT=high                     (high)  análisis profundo
# GESTIONA_RAZONADOR_EFFORT_REPASO=medium            (medium) repaso por lotes
# GESTIONA_RAZONADOR_LOTE=20                         (20) cuentas por llamada
# GESTIONA_RAZONADOR_COLCHON_DIAS=60                 (60) días sin alarma
